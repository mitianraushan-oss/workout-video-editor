# Copy this file to .env and fill in your key. .env is gitignored — never commit real keys.

# Used for both edit planning (chat model) and GPT Image 2 image edits.
OPENAI_API_KEY=

# Optional: override the planning model (default: gpt-5.1)
# OPENAI_PLANNER_MODEL=

# ---- Multi-provider AI generation layer (providers/) ----
# Dry-run is ON unless this is exactly 'false'. Leave ON until each provider's
# _call_real() branch is implemented and its API details in config/providers.json
# are verified. In dry-run no network calls are made.
PROVIDER_DRY_RUN=true

# Per-provider API keys. A provider is "unavailable" until its key is present.
# Names must match api_key_env in config/providers.json.
HIGGSFIELD_API_KEY=
KREA_API_KEY=
RUNWAY_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
