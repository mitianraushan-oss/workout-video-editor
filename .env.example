# Copy this file to .env and fill in your key. .env is gitignored — never commit real keys.

# Used for both edit planning (chat model) and GPT Image 2 image edits.
OPENAI_API_KEY=

# Optional: override the planning model (default: gpt-5.1)
# OPENAI_PLANNER_MODEL=

# ---- Multi-provider AI generation layer (providers/) ----
# Dry-run is ON unless this is exactly 'false'. When ON, no network calls are
# made (results are simulated). For the BYO-key studio (/static/ai-providers.html)
# to produce REAL output, set this to false.
PROVIDER_DRY_RUN=false

# OpenAI image model (image gen/edit). Your key can see gpt-image-1 / -1-mini /
# -1.5 / -2. Default is gpt-image-1; -1-mini is cheapest.
# OPENAI_IMAGE_MODEL=gpt-image-1

# Optional server-side fallback keys. NOT required for the BYO studio, where
# each user supplies their own key from the browser. These only apply when a
# request arrives without a key. Names must match api_key_env in providers.json.
HIGGSFIELD_API_KEY=
KREA_API_KEY=
RUNWAY_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
